    {
      "policy_id": "engine-policy",
      "revision": "engine-policy/1",
      "owner": "work-loop-engine",
      "allowed_classes": ["A", "B"],
      "required_signals": ["independent-review"],
      "required_gates": ["synthetic-pack-composition"],
      "required_reviewers": ["software-dev-reviewer"],
      "closer_authority_ref": "software-dev-reviewer",
