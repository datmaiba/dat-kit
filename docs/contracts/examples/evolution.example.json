    {
      "policy_id": "platform-contract-policy",
      "revision": "platform-contract-policy/1",
      "owner": "registry-platform",
      "allowed_classes": ["C"],
      "required_signals": ["independent-review"],
      "required_gates": ["full-cross-component-regression", "rollback-rehearsal"],
      "required_reviewers": ["software-dev-reviewer", "knowledge-work-reviewer"],
