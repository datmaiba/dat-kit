      "succession_rule": "current owner records a successor in a Class C decision",
      "approval_evidence_contract": "decision record, two independent reviews, regression, and rollback rehearsal",
      "revocation_rule": "owner or successor records revocation before effective_from_run"
    }
  ],
  "policies": [
    {
      "policy_id": "software-dev-policy",
      "revision": "software-dev-policy/1",
      "owner": "software-dev",
      "allowed_classes": ["A", "B"],
      "required_signals": ["independent-review"],
      "required_gates": ["software-regression"],
      "required_reviewers": ["software-dev-reviewer"],
      "closer_authority_ref": "software-dev-reviewer",
